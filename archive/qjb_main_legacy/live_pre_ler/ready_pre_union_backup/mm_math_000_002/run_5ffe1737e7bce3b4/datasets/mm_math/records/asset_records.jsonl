{"asset_id": "asset_1691273a4475602d9c007909", "problem_id": "prob_59be777020dd0083125f3413", "asset_type": "answer", "asset_role": "answer_raw", "source_uri": "source://mm_math/train/52950677.png/answer", "storage_uri": "inline://prob_59be777020dd0083125f3413/answer_raw", "file_format": "txt", "file_size_bytes": 210, "width": null, "height": null, "sha256": "c912950757738a06808327e8e29d22bf84e1f1b507a199a55b12f8dc1bc704a3", "perceptual_hash": null, "source_text_snapshot": "\\textbf{Solution:} From the construction, we have that $MN$ bisects $BC$ perpendicularly,\\\\\n$\\therefore DB=DC$,\\\\\n$\\therefore$ the perimeter of $\\triangle ACD = AC+AD+CD = AC+AD+BD = AC+AB = 5+12 = \\boxed{17}$.", "normalized_text_snapshot": null, "text_completeness_score": 1.0, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "From", "canonical": "From", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "we", "canonical": "we", "variable_type": "label"}, {"original": "have", "canonical": "have", "variable_type": "label"}, {"original": "that", "canonical": "that", "variable_type": "label"}, {"original": "MN", "canonical": "MN", "variable_type": "label"}, {"original": "BC", "canonical": "BC", "variable_type": "label"}, {"original": "DB", "canonical": "DB", "variable_type": "label"}, {"original": "DC", "canonical": "DC", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "ACD", "canonical": "ACD", "variable_type": "label"}, {"original": "AC", "canonical": "AC", "variable_type": "label"}, {"original": "AD", "canonical": "AD", "variable_type": "label"}, {"original": "CD", "canonical": "CD", "variable_type": "label"}, {"original": "BD", "canonical": "BD", "variable_type": "label"}, {"original": "AB", "canonical": "AB", "variable_type": "label"}], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-03-31T06:16:39Z", "updated_at": "2026-03-31T06:16:39Z"}
{"asset_id": "asset_2cb6bb1d642663efd8433f49", "problem_id": "prob_59be777020dd0083125f3413", "asset_type": "answer", "asset_role": "answer_normalized", "source_uri": null, "storage_uri": "inline://prob_59be777020dd0083125f3413/answer_normalized", "file_format": "txt", "file_size_bytes": 209, "width": null, "height": null, "sha256": "4bb2920f7307910de27000d522e4457466a7f6cc28598a097041b2bd607d8955", "perceptual_hash": null, "source_text_snapshot": "\\textbf{Solution:} From the construction, we have that $MN$ bisects $BC$ perpendicularly,\\\\\n$\\therefore DB=DC$,\\\\\n$\\therefore$ the perimeter of $\\triangle ACD = AC+AD+CD = AC+AD+BD = AC+AB = 5+12 = \\boxed{17}$.", "normalized_text_snapshot": "\\textbf{Solution:} From the construction, we have that $MN$ bisects $BC$ perpendicularly,\\\\\n$\\therefore DB=DC$,\\\\\n$\\therefore$ the perimeter of $\\triangle ACD = AC+AD+CD = AC+AD+BD = AC+AB = 5+12 = \\boxed{17}$", "text_completeness_score": 1.0, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "From", "canonical": "From", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "we", "canonical": "we", "variable_type": "label"}, {"original": "have", "canonical": "have", "variable_type": "label"}, {"original": "that", "canonical": "that", "variable_type": "label"}, {"original": "MN", "canonical": "MN", "variable_type": "label"}, {"original": "BC", "canonical": "BC", "variable_type": "label"}, {"original": "DB", "canonical": "DB", "variable_type": "label"}, {"original": "DC", "canonical": "DC", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "ACD", "canonical": "ACD", "variable_type": "label"}, {"original": "AC", "canonical": "AC", "variable_type": "label"}, {"original": "AD", "canonical": "AD", "variable_type": "label"}, {"original