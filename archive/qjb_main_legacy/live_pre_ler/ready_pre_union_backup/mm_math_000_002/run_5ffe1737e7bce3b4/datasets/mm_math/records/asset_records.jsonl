{"asset_id": "asset_b7f43056076903fc5b485661", "problem_id": "prob_c2964057acd862140710743a", "asset_type": "answer", "asset_role": "answer_raw", "source_uri": "source://mm_math/train/52950675.png/answer", "storage_uri": "inline://prob_c2964057acd862140710743a/answer_raw", "file_format": "txt", "file_size_bytes": 359, "width": null, "height": null, "sha256": "71f10d48c452823f42ab59753227bc84a3ee5c0c703763af3a414cca58ab1776", "perceptual_hash": null, "source_text_snapshot": "\\textbf{Solution:} Since $AD$ is the median of side $BC$ of $\\triangle ABC$, and the area of $\\triangle ABD$ is $12\\text{cm}^2$,\\\\\ntherefore, the area of $\\triangle ADC$ is: $\\frac{1}{2}\\times 12=6\\text{cm}^2$,\\\\\nSince $CE$ is the median of side $AD$ of $\\triangle ACD$,\\\\\ntherefore, the area of $\\triangle CDE$ is: $\\frac{1}{2}\\times 6=\\boxed{3}\\text{cm}^2$.", "normalized_text_snapshot": null, "text_completeness_score": 1.0, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "AD", "canonical": "AD", "variable_type": "label"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "side", "canonical": "side", "variable_type": "label"}, {"original": "BC", "canonical": "BC", "variable_type": "label"}, {"original": "ABC", "canonical": "ABC", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "area", "canonical": "area", "variable_type": "label"}, {"original": "ABD", "canonical": "ABD", "variable_type": "label"}, {"original": "text", "canonical": "text", "variable_type": "label"}, {"original": "cm", "canonical": "cm", "variable_type": "label"}, {"original": "ADC", "canonical": "ADC", "variable_type": "label"}, {"original": "frac", "canonical": "