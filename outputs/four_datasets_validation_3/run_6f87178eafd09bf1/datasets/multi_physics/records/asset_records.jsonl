{"asset_id": "asset_d454726ac55b3928b104f2bd", "problem_id": "prob_3d17e7a825a62e2a42f27a29", "asset_type": "text", "asset_role": "question_text_source", "source_uri": "source://multi_physics/repo_discovered/2/question", "storage_uri": "inline://prob_3d17e7a825a62e2a42f27a29/question_source", "file_format": "txt", "file_size_bytes": 309, "width": null, "height": null, "sha256": "015695c57a47f1a6faab7bf3cbe2adc3a59e56a9c455ed29e12d64da1921469f", "perceptual_hash": null, "source_text_snapshot": "一个人从北京去重庆,可以乘火车,也可以坐飞机,还可以先乘火车到武汉,然后乘轮船沿长江到重庆,如图所示,这两种情况下:\n①他的运动轨迹不一样 ②他走过的路程相同 ③他的位置变动是不同的 ④他的位移是相同的\n以上说法正确的是( )", "normalized_text_snapshot": null, "text_completeness_score": 0.65, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-04-03T17:58:24Z", "updated_at": "2026-04-03T17:58:24Z"}
{"asset_id": "asset_503a74ff7b764d7b499175bf", "problem_id": "prob_3d17e7a825a62e2a42f27a29", "asset_type": "text", "asset_role": "question_text_normalized", "source_uri": null, "storage_uri": "inline://prob_3d17e7a825a62e2a42f27a29/question_normalized", "file_format": "txt", "file_size_bytes": 330, "width": null, "height": null, "sha256": "9ec7b212bf380b599c71647ce9714551bea76bbec518a921b5a9275bcb4b42e7", "perceptual_hash": null, "source_text_snapshot": "一个人从北京去重庆,可以乘火车,也可以坐飞机,还可以先乘火车到武汉,然后乘轮船沿长江到重庆,如图所示,这两种情况下:\n①他的运动轨迹不一样 ②他走过的路程相同 ③他的位置变动是不同的 ④他的位移是相同的\n以上说法正确的是( )", "normalized_text_snapshot": "一个人从北京去重庆，可以乘火车，也可以坐飞机，还可以先乘火车到武汉，然后乘轮船沿长江到重庆，如图所示。这两种情况下：①他的运动轨迹不一样；②他走过的路程相同；③他的位置变动是不同的；④他的位移是相同的。以上说法正确的是( )", "text_completeness_score": 0.65, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-04-03T17:58:24Z", "updated_at": "2026-04-03T17:58:24Z"}
