{"node_id": "node_ab14d79a4b2fd4cc1887d7e5", "problem_id": "prob_20e7806428521f0a8aafd57e", "node_type": "target_slot", "canonical_value": "If the area of $ \\triangle ABC$ is $12\\text{cm}^2$, what is the area of $ \\triangle CDE$?", "surface_forms": ["If the area of $ \\triangle ABC$ is $12\\text{cm}^2$, what is the area of $ \\triangle CDE$?"], "origin_kind": "text_structure", "cognitive_level": "computed", "source_refs": ["asset_adccb39931372dcc106112a9"], "evidence_refs": ["asset_adccb39931372dcc106112a9"], "upstream_node_ids": [], "value_type": "set", "normalized_value": {"slot_id": "slot_prob_20e7806428521f0a8aafd57e_1", "variant_index": 1, "split_role": "single", "slot_type": "set", "target_text": "If the area of $ \\triangle ABC$ is $12\\text{cm}^2$, what is the area of $ \\triangle CDE$?", "expected_answer_type": "set", "expected_answer": "\\textbf{Solution:} Since $AD$ is the median of side $BC$ of $\\triangle ABC$, and the area of $\\triangle ABD$ is $12\\text{cm}^2$,\\\\\ntherefore, the area of $\\triangle ADC$ is: $\\frac{1}{2}\\times 12=6\\text{cm}^2$,\\\\\nSince $CE$ is the median of side $AD$ of $\\triangle ACD$,\\\\\ntherefore, the area of $\\triangle CDE$ is: $\\frac{1}{2}\\times 6=\\boxed{3}\\text{cm}^2$", "requires_visual_grounding": true}, "unit": null, "confidence": 0.92, "verifiability": "high", "ambiguity_level": "low", "is_direct_from_source": false, "is_generated_by_system": true, "is_reviewed_by_human": false, "stage_created": "cleaning", "status": "active", "version": 1, "created_at": "2026-04-03T17:52:49Z", "updated_at": "2026-04-03T17:52:49Z"}
