{"asset_id": "asset_95bbde41b682acf58bcece5b", "problem_id": "prob_9b959934c2ff73d063c5beb8", "asset_type": "text", "asset_role": "question_text_normalized", "source_uri": null, "storage_uri": "inline://prob_9b959934c2ff73d063c5beb8/question_normalized", "file_format": "txt", "file_size_bytes": 171, "width": null, "height": null, "sha256": "46251385830d892793fd61f08101414365b5fae9d9cd11e314883cc6e35767d9", "perceptual_hash": null, "source_text_snapshot": "As shown in the figure, $OP$ bisects $\\angle AOB$, where point $E$ is on $OA$ with $OE = 4$, and the distance from point $P$ to $OB$ is $2$. What is the area of $\\triangle POE$?", "normalized_text_snapshot": "As shown in the figure, $OP$ bisects $\\angle AOB$. Point $E$ is on $OA$ with $OE = 4$, and the distance from point $P$ to $OB$ is $2$. What is the area of $\\triangle POE$?", "text_completeness_score": 0.7027, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "As", "canonical": "As", "variable_type": "label"}, {"original": "in", "canonical": "in", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "OP", "canonical": "OP", "variable_type": "label"}, {"original": "AOB", "canonical": "AOB", "variable_type": "label"}, {"original": "E", "canonical": "E", "variable_type": "symbol"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "on", "canonical": "on", "variable_type": "label"}, {"original": "OA", "canonical": "OA", "variable_type": "label"}, {"original": "with", "canonical": "with", "variable_type": "label"}, {"original": "OE", "canonical": "OE", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "P", "canonical": "P", "variable_type": "symbol"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "OB", "canonical": "OB", "variable_type": "label"}, {"original": "area", "canonical": "area", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "POE", "canonical": "POE", "variable_type": "label"}], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-04-03T17:53:45Z", "updated_at": "2026-04-03T17:53:45Z"}
{"asset_id": "asset_399a8581d0ba6cc4008cfd28", "problem_id": "prob_9b959934c2ff73d063c5beb8", "asset_type": "answer", "asset_role": "answer_raw", "source_uri": "source://mm_math/train/52950518.png/answer", "storage_uri": "inline://prob_9b959934c2ff73d063c5beb8/answer_raw", "file_format": "txt", "file_size_bytes": 226, "width": null, "height": null, "sha256": "9f26fb2512d0ad1119b795f9074aabca8a65f68cb06abe0172dca95a69edf62e", "perceptual_hash": null, "source_text_snapshot": "\\textbf{Solution:} Since OP bisects $\\angle$AOB, and the distance from point P to OB is 2, \\\\\n$\\therefore$ the distance from point P to OA is also 2, \\\\\n$\\therefore$ $ {S}_{\\triangle OEP}=\\frac{1}{2}\\times 4\\times 2=\\boxed{4}$", "normalized_text_snapshot": null, "text_completeness_score": 1.0, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "OP", "canonical": "OP", "variable_type": "label"}, {"original": "AOB", "canonical": "AOB", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "P", "canonical": "P", "variable_type": "symbol"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "OB", "canonical": "OB", "variable_type": "label"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "OA", "canonical": "OA", "variable_type": "label"}, {"original": "also", "canonical": "also", "variable_type": "label"}, {"original": "OEP", "canonical": "OEP", "variable_type": "label"}, {"original": "frac", "canonical": "frac", "variable_type": "label"}], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-04-03T17:53:45Z", "updated_at": "2026-04-03T17:53:45Z"}
{"asset_id": "asset_2b9a070df07c4228efc94381", "problem_id": "prob_9b959934c2ff73d063c5beb8", "asset_type": "answer", "asset_role": "answer_normalized", "source_uri": null, "storage_uri": "inline://prob_9b959934c2ff73d063c5beb8/answer_normalized", "file_format": "txt", "file_size_bytes": 196, "width": null, "height": null, "sha256": "d60ebf9de6b0c27e1fc6a2412f697c9d69aaafc03297b5b276cec358a3129c9b", "perceptual_hash": null, "source_text_snapshot": "\\textbf{Solution:} Since OP bisects $\\angle$AOB, and the distance from point P to OB is 2, \\\\\n$\\therefore$ the distance from point P to OA is also 2, \\\\\n$\\therefore$ $ {S}_{\\triangle OEP}=\\frac{1}{2}\\times 4\\times 2=\\boxed{4}$", "normalized_text_snapshot": "Since $OP$ bisects $\\angle AOB$ and the distance from point $P$ to $OB$ is $2$, the distance from point $P$ to $OA$ is also $2$. Therefore, $S_{\\triangle OEP} = \\frac{1}{2} \\times 4 \\times 2 = 4$.", "text_completeness_score": 1.0, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "OP", "canonical": "OP", "variable_type": "label"}, {"original": "AOB", "canonical": "AOB", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "P", "canonical": "P", "variable_type": "symbol"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "OB", "canonical": "OB", "variable_type": "label"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "OA", "canonical": "OA", "variable_type": "label"}, {"original": "also", "canonical": "also", "variable_type": "label"}, {"original": "OEP", "canonical": "OEP", "variable_type": "label"}, {"original": "frac", "canonical": "frac", "variable_type": "label"}], "asse