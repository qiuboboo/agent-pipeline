{"asset_id": "asset_c4d28655d51a655ae9735c5b", "problem_id": "prob_20e7806428521f0a8aafd57e", "asset_type": "text", "asset_role": "question_text_source", "source_uri": "source://mm_math/train/52950675.png/question", "storage_uri": "inline://prob_20e7806428521f0a8aafd57e/question_source", "file_format": "txt", "file_size_bytes": 193, "width": null, "height": null, "sha256": "05fb3dd23ee51c83cd78234daec6c413b098b65d10d83fc4dad7f435cb6fabd0", "perceptual_hash": null, "source_text_snapshot": "As shown in the figure, $AD$ is the median of $ \\triangle ABC$, $CE$ is the median of $ \\triangle ACD$. If the area of $ \\triangle ABC$ is $12\\text{cm}^2$, what is the area of $ \\triangle CDE$?", "normalized_text_snapshot": null, "text_completeness_score": 0.7223, "blur_score": null, "readability_score": null, "noise_score": null, "cropped_from_asset_id": null, "roi_bbox": null, "unit_normalization_map": [], "variable_aliases": [{"original": "As", "canonical": "As", "variable_type": "label"}, {"original": "in", "canonical": "in", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "AD", "canonical": "AD", "variable_type": "label"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "ABC", "canonical": "ABC", "variable_type": "label"}, {"original": "CE", "canonical": "CE", "variable_type": "label"}, {"original": "ACD", "canonical": "ACD", "variable_type": "label"}, {"original": "If", "canonical": "If", "variable_type": "label"}, {"original": "area", "canonical": "area", "variable_type": "label"}, {"original": "text", "canonical": "text", "variable_type": "label"}, {"original": "cm", "canonical": "cm", "variable_type": "label"}, {"original": "CDE", "canonical": "CDE", "variable_type": "label"}], "asset_quality_flags": [], "is_usable": true, "discard_reason_codes": [], "created_at": "2026-04-03T17:52:49Z", "updated_at": "2026-04-03T17: