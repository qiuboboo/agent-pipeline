{"clean_problem_record_id": "cleanprob_f5d2f9a7f5dc15e9d3252ce6", "problem_id": "prob_1fbe17732105c62577cc4fd2", "source_dataset": "Multi-Physics", "source_problem_id": "3", "normalized_question_text": "右图是体育摄影中“追拍法”的成功之作,摄影师眼中清晰的滑板运动员是静止的,而模糊的背景是运动的,摄影师用自己的方式表达了运动的美。请问摄影师选择的参考系是( )", "normalized_answer_text": "摄像机", "image_count": 1, "has_multiple_images": false, "requires_image": true, "text_dominant": false, "cleaning_path": "multimodal_full", "question_type": "multiple_choice", "open_variant_count": 1, "alignment_status": "bad", "solvability_score": 0.8, "solvability_path_mode": "multimodal", "clean_decision": "reject", "decision_reason_codes": ["bad_alignment", "low_resolution", "missing_grounded_visual_path", "no_visual_grounding", "severe_crop_loss", "text_image_misaligned"], "created_at": "2026-03-27T21:55:05Z"}
