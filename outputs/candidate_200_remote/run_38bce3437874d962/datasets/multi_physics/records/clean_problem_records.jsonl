{"clean_problem_record_id": "cleanprob_20de06756204fce60859ab3f", "problem_id": "prob_01262dac2ad843fc5ed117ac", "source_dataset": "Multi-Physics", "source_problem_id": "13", "normalized_question_text": "如图所示曲线为一质点沿y轴运动的位置—时间(y­t)图像,设竖直向上为y轴正方向,已知图线为一条抛物线,则由图像可知", "normalized_answer_text": "$t_1\\sim_{t_3}$时间内质点相对坐标原点O的位移先为正后为负", "image_count": 1, "has_multiple_images": false, "requires_image": true, "text_dominant": false, "cleaning_path": "multimodal_full", "question_type": "multiple_choice", "open_variant_count": 1, "alignment_status": "bad", "solvability_score": 0.8, "solvability_path_mode": "multimodal", "clean_decision": "reject", "decision_reason_codes": ["alignment_bad", "low_alignment_consistency", "missing_grounded_visual_path", "no_reasoning_path", "text_image_misaligned"], "created_at": "2026-03-27T22:03:51Z"}
