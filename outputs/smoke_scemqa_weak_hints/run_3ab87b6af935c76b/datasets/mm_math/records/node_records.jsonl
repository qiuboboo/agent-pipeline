{"node_id": "node_0011283df98cc9d8b8a352d6", "problem_id": "prob_c11f4ea0de15f097c71f67f5", "node_type": "target_slot", "canonical_value": "If $AC = 5$ and $AB = 12$, what is the perimeter of $\\triangle ACD$?", "surface_forms": ["If $AC = 5$ and $AB = 12$, what is the perimeter of $\\triangle ACD$?"], "origin_kind": "text_structure", "cognitive_level": "computed", "source_refs": ["asset_a5252f916718d3fdd7757380"], "evidence_refs": ["asset_a5252f916718d3fdd7757380"], "upstream_node_ids": [], "value_type": "set", "normalized_value": {"slot_id": "slot_prob_c11f4ea0de15f097c71f67f5_1", "variant_index": 1, "split_role": "single", "slot_type": "set", "target_text": "If $AC = 5$ and $AB = 12$, what is the perimeter of $\\triangle ACD$?", "expected_answer_type": "set", "expected_answer": "\\textbf{Solution:} From the construction, we have that $MN$ bisects $BC$ perpendicularly,\\\\\n$\\therefore DB=DC$,\\\\\n$\\therefore$ the perimeter of $\\triangle ACD = AC+AD+CD = AC+AD+BD = AC+AB = 5+12 = \\boxed{17}$", "requires_visual_grounding": true}, "unit": null, "confidence": 0.92, "verifiability": "high", "ambiguity_level": "low", "is_direct_from_source": false, "is_generated_by_system": true, "is_reviewed_by_human": false, "stage_created": "cleaning", "status": "active", "version": 1, "created_at": "2026-03-27T08:36:23Z", "updated_at": "2026-03-27T08:36:23Z"}
