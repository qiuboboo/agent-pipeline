{"text_structure_id": "text_prob_dc162ca4ebdec94f04ed6998", "problem_id": "prob_dc162ca4ebdec94f04ed6998", "question_type": "open", "conditions": [{"text": "A small block C slides onto the skateboard from its leftmost end with an initial velocity $v_{0}$.", "segment_index": 4, "mentions_visual": false, "numeric_tokens": ["0"], "unit_mentions": ["A", "h", "m", "s"], "condition_role": "explicit"}, {"text": "After traveling a distance of $s_{0}$, it undergoes a perfectly inelastic collision with B (the collision time is extremely short), and then they move together to the right.", "segment_index": 5, "mentions_visual": false, "numeric_tokens": ["0"], "unit_mentions": ["A", "g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "After a certain period, the skateboard A also begins to move.", "segment_index": 6, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["A", "g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "1.", "segment_index": 11, "mentions_visual": false, "numeric_tokens": ["1"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "2.", "segment_index": 13, "mentions_visual": false, "numeric_tokens": ["2"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "3.", "segment_index": 15, "mentions_visual": false, "numeric_tokens": ["3"], "unit_mentions": [], "condition_role": "explicit"}], "targets": [{"text": "What is the magnitude of the velocity of C just before the collision?", "segment_index": 12, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["W", "g", "h", "m", "s"], "target_role": "primary"}, {"text": "What is the mechanical energy loss during the collision between C and B?", "segment_index": 14, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["W", "g", "h", "m", "s"], "target_role": "primary"}, {"text": "How much work is done by C and B against friction from the instant of the collision until A begins to move?", "segment_index": 16, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["A", "g", "h", "m", "s"], "target_role": "primary"}], "answer_slots": [{"slot_id": "slot_prob_dc162ca4ebdec94f04ed6998_1", "variant_index": 1, "split_role": "single", "slot_type": "short_text", "target_text": "What is the mechanical energy loss during the collision between C and B?", "expected_answer_type": "short_text", "expected_answer": "$\\sqrt{v_{0}^{2}-2\\mu g s_{0}}$\n$\\frac{1}{4}m(v_{0}^{2}-2\\mu g s_{0})$\n$\\frac{2\\mu^{2}m^{2}g^{2}}{k}$", "requires_visual_grounding": false}], "entity_mentions": [{"mention": "L", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "A", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "B", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "C", "entity_category": "label", "requires_visual_grounding": true}], "variable_aliases": [{"original": "An", "canonical": "An", "variable_type": "label"}, {"original": "L", "canonical": "L", "variable_type": "symbol"}, {"original": "A", "canonical": "A", "variable_type": "symbol"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "at", "canonical": "at", "variable_type": "label"}, {"original": "rest", "canonical": "rest", "variable_type": "label"}, {"original": "on", "canonical": "on", "variable_type": "label"}, {"original": "a", "canonical": "a", "variable_type": "symbol"}, {"original": "with", "canonical": "with", "variable_type": "label"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "k", "canonical": "k", "variable_type": "symbol"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "end", "canonical": "end", "variable_type": "label"}, {"original": "The", "canonical": "The", "variable_type": "label"}, {"original": "left", "canonical": "left", "variable_type": "label"}, {"original": "B", "canonical": "B", "variable_type": "symbol"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "its", "canonical": "its", "variable_type": "label"}, {"original": "C", "canonical": "C", "variable_type": "symbol"}, {"original": "onto", "canonical": "onto", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "an", "canonical": "an", "variable_type": "label"}, {"original": "it", "canonical": "it", "variable_type": "label"}, {"original": "time", "canonical": "time", "variable_type": "label"}, {"original": "then", "canonical": "then", "variable_type": "label"}, {"original": "they", "canonical": "they", "variable_type": "label"}, {"original": "move", "canonical": "move", "variable_type": "label"}, {"original": "also", "canonical": "also", "variable_type": "label"}, {"original": "are", "canonical": "are", "variable_type": "label"}, {"original": "all", "canonical": "all", "variable_type": "label"}, {"original": "m", "canonical": "m", "variable_type": "symbol"}, {"original": "both", "canonical": "both", "variable_type": "label"}, {"original": "mu", "canonical": "mu", "variable_type": "label"}, {"original": "g", "canonical": "g", "variable_type": "symbol"}, {"original": "just", "canonical": "just", "variable_type": "label"}, {"original": "loss", "canonical": "loss", "variable_type": "label"}, {"original": "How", "canonical": "How", "variable_type": "label"}, {"original": "much", "canonical": "much", "variable_type": "label"}, {"original": "work", "canonical": "work", "variable_type": "label"}, {"original": "done", "canonical": "done", "variable_type": "label"}, {"original": "by", "canonical": "by", "variable_type": "label"}], "unit_mentions": ["A", "W", "g", "h", "m", "s"], "sentence_segments": [{"segment_index": 1, "text": "An L-shaped skateboard A is initially at rest on a rough horizontal surface."}, {"segment_index": 2, "text": "A light spring with a spring constant of $k$ is fixed to the right end of the skateboard."}, {"segment_index": 3, "text": "The left end of the spring is connected to a small block B, and the spring is initially at its natural length."}, {"segment_index": 4, "text": "A small block C slides onto the skateboard from its leftmost end with an initial velocity $v_{0}$."}, {"segment_index": 5, "text": "After traveling a distance of $s_{0}$, it undergoes a perfectly inelastic collision with B (the collision time is extremely short), and then they move together to the right."}, {"segment_index": 6, "text": "After a certain period, the skateboard A also begins to move."}, {"segment_index": 7, "text": "The masses of A, B, and C are all m."}, {"segment_index": 8, "text": "The coefficient of kinetic friction between the skateboard and the small blocks, and between the skateboard and the ground, are both $\\mu$."}, {"segment_index": 9, "text": "The magnitude of gravitational acceleration is $g$."}, {"segment_index": 10, "text": "The maximum static friction is approximately equal to the sliding friction, and the spring remains within its elastic limit throughout."}, {"segment_index": 11, "text": "1."}, {"segment_index": 12, "text": "What is the magnitude of the velocity of C just before the collision?"}, {"segment_index": 13, "text": "2."}, {"segment_index": 14, "text": "What is the mechanical energy loss during the collision between C and B?"}, {"segment_index": 15, "text": "3."}, {"segment_index": 16, "text": "How much work is done by C and B against friction from the instant of the collision until A begins to move?"}], "requires_visual_grounding": true, "text_structure_status": "complete", "parser_confidence": 0.92, "created_at": "2026-04-05T14:01:12Z"}
{"text_structure_id": "text_prob_68f541df77cd351725b838ba", "problem_id": "prob_68f541df77cd351725b838ba", "question_type": "calculation", "conditions": [{"text": "The string remains taut, and when it reaches its lowest point, it undergoes an elastic head-on collision with block $a$.", "segment_index": 6, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "Given $m=2g$, $l=1m$, $R=0.4m$, $H=0.2m$, $v=2m/s$, and the coefficient of kinetic friction between the block and MN, CD is $\\mu=0.5$.", "segment_index": 7, "mentions_visual": false, "numeric_tokens": ["2", "1", "0.4", "0.2", "2", "0.5"], "unit_mentions": ["N", "g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "Treat the blocks as point masses, and let $g=10m/\\mathrm{s}^{2}$.", "segment_index": 12, "mentions_visual": false, "numeric_tokens": ["10", "2"], "unit_mentions": ["g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "1.", "segment_index": 13, "mentions_visual": false, "numeric_tokens": ["1"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "2.", "segment_index": 15, "mentions_visual": false, "numeric_tokens": ["2"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "3.", "segment_index": 17, "mentions_visual": false, "numeric_tokens": ["3"], "unit_mentions": [], "condition_role": "explicit"}], "targets": [{"text": "If $h=1.25m$, determine the magnitude of the velocity $v_{0}$ of block $a$ immediately after the collision with block $b$.", "segment_index": 14, "mentions_visual": false, "numeric_tokens": ["1.25", "0"], "unit_mentions": ["g", "h", "m", "min", "mm", "s"], "target_role": "primary"}, {"text": "Determine the relationship between the normal force $F_{N}$ exerted by the pipe on block $a$ when it is at the highest point of $DE$ and the height $h$.", "segment_index": 16, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["N", "g", "h", "m", "min", "s"], "target_role": "primary"}, {"text": "If the release height of block $b$ is $0.9m<h<1.65m$, determine the range of the final resting position $x$ of block $a$ (with point $A$ as the origin and the horizontal direction to the right as positive, establishing the x-axis).", "segment_index": 18, "mentions_visual": false, "numeric_tokens": ["0.9", "1.65"], "unit_mentions": ["A", "g", "h", "m", "min", "s"], "target_role": "primary"}], "answer_slots": [{"slot_id": "slot_prob_68f541df77cd351725b838ba_1", "variant_index": 1, "split_role": "single", "slot_type": "set", "target_text": "If the release height of block $b$ is $0.9m<h<1.65m$, determine the range of the final resting position $x$ of block $a$ (with point $A$ as the origin and the horizontal direction to the right as positive, establishing the x-axis).", "expected_answer_type": "set", "expected_answer": "5\\mathrm{m/s}\nF_{N}=0.1h-0.14(N) (h \\geq 1.2m, direction of $F_{N}$ is vertically downwards)\nwhen $0.9m<h<1.2m$,$2.6m{<}x{\\leq}3m$,When $1.2m \\leq h \\leq 1.65m$,$(3+{\\frac{\\sqrt{3}}{5}})m \\leq x \\leq (3.6+{\\frac{\\sqrt{3}}{5}})m$", "requires_visual_grounding": false}], "entity_mentions": [{"mention": "point", "entity_category": "point", "requires_visual_grounding": true}, {"mention": "axis", "entity_category": "axis", "requires_visual_grounding": true}, {"mention": "A", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "O", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "MN", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "AB", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "CD", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "FG", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "DE", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "R", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "EF", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "E", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "H", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "M", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "B", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "N", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "C", "entity_category": "label", "requires_visual_grounding": true}], "variable_aliases": [{"original": "In", "canonical": "In", "variable_type": "label"}, {"original": "a", "canonical": "a", "variable_type": "symbol"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "mass", "canonical": "mass", "variable_type": "label"}, {"original": "m", "canonical": "m", "variable_type": "symbol"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "at", "canonical": "at", "variable_type": "label"}, {"original": "rest", "canonical": "rest", "variable_type": "label"}, {"original": "A", "canonical": "A", "variable_type": "symbol"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "O", "canonical": "O", "variable_type": "symbol"}, {"original": "belt", "canonical": "belt", "variable_type": "label"}, {"original": "MN", "canonical": "MN", "variable_type": "label"}, {"original": "with", "canonical": "with", "variable_type": "label"}, {"original": "v", "canonical": "v", "variable_type": "symbol"}, {"original": "AB", "canonical": "AB", "variable_type": "label"}, {"original": "CD", "canonical": "CD", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "FG", "canonical": "FG", "variable_type": "label"}, {"original": "The", "canonical": "The", "variable_type": "label"}, {"original": "are", "canonical": "are", "variable_type": "label"}, {"original": "all", "canonical": "all", "variable_type": "label"}, {"original": "l", "canonical": "l", "variable_type": "symbol"}, {"original": "arc", "canonical": "arc", "variable_type": "label"}, {"original": "thin", "canonical": "thin", "variable_type": "label"}, {"original": "pipe", "canonical": "pipe", "variable_type": "label"}, {"original": "DE", "canonical": "DE", "variable_type": "label"}, {"original": "R", "canonical": "R", "variable_type": "symbol"}, {"original": "EF", "canonical": "EF", "variable_type": "label"}, {"original": "lies", "canonical": "lies", "variable_type": "label"}, {"original": "on", "canonical": "on", "variable_type": "label"}, {"original": "E", "canonical": "E", "variable_type": "symbol"}, {"original": "H", "canonical": "H", "variable_type": "symbol"}, {"original": "b", "canonical": "b", "variable_type": "symbol"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "left", "canonical": "left", "variable_type": "label"}, {"original": "h", "canonical": "h", "variable_type": "symbol"}, {"original": "taut", "canonical": "taut", "variable_type": "label"}, {"original": "when", "canonical": "when", "variable_type": "label"}, {"original": "it", "canonical": "it", "variable_type": "label"}, {"original": "its", "canonical": "its", "variable_type": "label"}, {"original": "an", "canonical": "an", "variable_type": "label"}, {"original": "head", "canonical": "head", "variable_type": "label"}, {"original": "s", "canonical": "s", "variable_type": "symbol"}, {"original": "mu", "canonical": "mu", "variable_type": "label"}, {"original": "upon", "canonical": "upon", "variable_type": "label"}, {"original": "gaps", "canonical": "gaps", "variable_type": "label"}, {"original": "M", "canonical": "M", "variable_type": "symbol"}, {"original": "B", "canonical": "B", "variable_type": "symbol"}, {"original": "N", "canonical": "N", "variable_type": "symbol"}, {"original": "C", "canonical": "C", "variable_type": "symbol"}, {"original": "as", "canonical": "as", "variable_type": "label"}, {"original": "let", "canonical": "let", "variable_type": "label"}, {"original": "g", "canonical": "g", "variable_type": "symbol"}, {"original": "If", "canonical": "If", "variable_type": "label"}, {"original": "by", "canonical": "by", "variable_type": "label"}, {"original": "x", "canonical": "x", "variable_type": "symbol"}, {"original": "axis", "canonical": "axis", "variable_type": "label"}], "unit_mentions": ["A", "N", "W", "g", "h", "m", "min", "mm", "s"], "sentence_segments": [{"segment_index": 1, "text": "In a vertical plane, a block $a$ of mass $m$ is initially at rest at point $A$ directly below the suspension point $O$."}, {"segment_index": 2, "text": "A conveyor belt MN, rotating counterclockwise with a velocity $v$, is coplanar with the horizontal tracks AB, CD, and FG."}, {"segment_index": 3, "text": "The lengths of AB, MN, and CD are all $l$."}, {"segment_index": 4, "text": "The radius of the circular arc thin pipe DE is $R$, and EF lies on the vertical diameter, with point $E$ at a height $H$."}, {"segment_index": 5, "text": "Initially, a block $b$, identical to block $a$, is suspended from point $O$ and pulled to the left to a height $h$ before being released from rest."}, {"segment_index": 6, "text": "The string remains taut, and when it reaches its lowest point, it undergoes an elastic head-on collision with block $a$."}, {"segment_index": 7, "text": "Given $m=2g$, $l=1m$, $R=0.4m$, $H=0.2m$, $v=2m/s$, and the coefficient of kinetic friction between the block and MN, CD is $\\mu=0.5$."}, {"segment_index": 8, "text": "Tracks AB and pipe DE are frictionless."}, {"segment_index": 9, "text": "Block $a$ comes to rest without bouncing upon landing on FG."}, {"segment_index": 10, "text": "Neglect the gaps between $M$, $B$, $N$, $C$."}, {"segment_index": 11, "text": "CD is smoothly connected to DE."}, {"segment_index": 12, "text": "Treat the blocks as point masses, and let $g=10m/\\mathrm{s}^{2}$."}, {"segment_index": 13, "text": "1."}, {"segment_index": 14, "text": "If $h=1.25m$, determine the magnitude of the velocity $v_{0}$ of block $a$ immediately after the collision with block $b$."}, {"segment_index": 15, "text": "2."}, {"segment_index": 16, "text": "Determine the relationship between the normal force $F_{N}$ exerted by the pipe on block $a$ when it is at the highest point of $DE$ and the height $h$."}, {"segment_index": 17, "text": "3."}, {"segment_index": 18, "text": "If the release height of block $b$ is $0.9m<h<1.65m$, determine the range of the final resting position $x$ of block $a$ (with point $A$ as the origin and the horizontal direction to the right as positive, establishing the x-axis)."}], "requires_visual_grounding": true, "text_structure_status": "complete", "parser_confidence": 0.92, "created_at": "2026-04-05T14:01:17Z"}
{"text_structure_id": "text_prob_a30b00cf7c9fa77f81c3a1e2", "problem_id": "prob_a30b00cf7c9fa77f81c3a1e2", "question_type": "calculation", "conditions": [{"text": "The magnitude of the air resistance experienced by the basketball during its motion is $\\lambda$ times the magnitude of the gravitational force acting on the basketball (where $\\lambda$ is a constant and $0<\\lambda<\\frac{H-h}{H+h}$).", "segment_index": 3, "mentions_visual": false, "numeric_tokens": ["0"], "unit_mentions": ["g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "1.", "segment_index": 6, "mentions_visual": false, "numeric_tokens": ["1"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "2.", "segment_index": 8, "mentions_visual": false, "numeric_tokens": ["2"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "If the basketball rebounds to the maximum height $h$, and at the instant the basketball reaches this maximum height, the athlete applies a downward force $F$, causing the basketball to rebound exactly to the height $h$ after colliding with the ground once.", "segment_index": 9, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "The force $F$ varies with height $y$ as shown in figure (b), where $h_{0}$ is known.", "segment_index": 10, "mentions_visual": true, "numeric_tokens": ["0"], "unit_mentions": ["g", "h", "s"], "condition_role": "explicit"}, {"text": "3.", "segment_index": 12, "mentions_visual": false, "numeric_tokens": ["3"], "unit_mentions": [], "condition_role": "explicit"}, {"text": "After being dropped from rest at height $H$, each time the basketball reaches its maximum rebound height, the athlete strikes it (with an extremely short impact duration), instantaneously giving it an equal, downward impulse $I$.", "segment_index": 13, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["A", "g", "h", "m", "s"], "condition_role": "explicit"}, {"text": "After $N$ such strikes, the basketball rebounds to height $H$ again.", "segment_index": 14, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["A", "N", "g", "h", "s"], "condition_role": "explicit"}], "targets": [{"text": "Determine the ratio of the post-collision velocity to the pre-collision velocity of the basketball during its collision with the ground.", "segment_index": 7, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["g", "h", "m", "min", "s"], "target_role": "primary"}, {"text": "Calculate the magnitude of $F_{0}$.", "segment_index": 11, "mentions_visual": false, "numeric_tokens": ["0"], "unit_mentions": ["g", "h", "m"], "target_role": "primary"}, {"text": "Calculate the magnitude of the impulse $I$.", "segment_index": 15, "mentions_visual": false, "numeric_tokens": [], "unit_mentions": ["g", "h", "m", "s"], "target_role": "primary"}], "answer_slots": [{"slot_id": "slot_prob_a30b00cf7c9fa77f81c3a1e2_1", "variant_index": 1, "split_role": "single", "slot_type": "short_text", "target_text": "Calculate the magnitude of the impulse $I$.", "expected_answer_type": "short_text", "expected_answer": "$k=\\sqrt{\\frac{(1+\\lambda)h}{(1-\\lambda)H}}$\n$F_{0}=\\frac{2m g(1-\\lambda)(H-h)}{h-h_{0}}$\n$I=m\\sqrt{\\frac{2g(1-\\lambda)(H-h)(H^{N+1}-h^{N+1})}{h(H^{N}-h^{N})}}$", "requires_visual_grounding": true}], "entity_mentions": [{"mention": "figure", "entity_category": "figure", "requires_visual_grounding": true}, {"mention": "A", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "H", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "F", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "I", "entity_category": "label", "requires_visual_grounding": true}, {"mention": "N", "entity_category": "label", "requires_visual_grounding": true}], "variable_aliases": [{"original": "A", "canonical": "A", "variable_type": "symbol"}, {"original": "of", "canonical": "of", "variable_type": "label"}, {"original": "mass", "canonical": "mass", "variable_type": "label"}, {"original": "m", "canonical": "m", "variable_type": "symbol"}, {"original": "is", "canonical": "is", "variable_type": "label"}, {"original": "from", "canonical": "from", "variable_type": "label"}, {"original": "rest", "canonical": "rest", "variable_type": "label"}, {"original": "at", "canonical": "at", "variable_type": "label"}, {"original": "a", "canonical": "a", "variable_type": "symbol"}, {"original": "H", "canonical": "H", "variable_type": "symbol"}, {"original": "the", "canonical": "the", "variable_type": "label"}, {"original": "It", "canonical": "It", "variable_type": "label"}, {"original": "an", "canonical": "an", "variable_type": "label"}, {"original": "with", "canonical": "with", "variable_type": "label"}, {"original": "and", "canonical": "and", "variable_type": "label"}, {"original": "to", "canonical": "to", "variable_type": "label"}, {"original": "h", "canonical": "h", "variable_type": "symbol"}, {"original": "The", "canonical": "The", "variable_type": "label"}, {"original": "air", "canonical": "air", "variable_type": "label"}, {"original": "by", "canonical": "by", "variable_type": "label"}, {"original": "its", "canonical": "its", "variable_type": "label"}, {"original": "on", "canonical": "on", "variable_type": "label"}, {"original": "frac", "canonical": "frac", "variable_type": "label"}, {"original": "post", "canonical": "post", "variable_type": "label"}, {"original": "pre", "canonical": "pre", "variable_type": "label"}, {"original": "same", "canonical": "same", "variable_type": "label"}, {"original": "for", "canonical": "for", "variable_type": "label"}, {"original": "each", "canonical": "each", "variable_type": "label"}, {"original": "g", "canonical": "g", "variable_type": "symbol"}, {"original": "If", "canonical": "If", "variable_type": "label"}, {"original": "this", "canonical": "this", "variable_type": "label"}, {"original": "F", "canonical": "F", "variable_typ